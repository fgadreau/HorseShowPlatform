# Frontend-safe values. These are used by Vite in the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy Supabase projects may still use an anon key.
VITE_SUPABASE_ANON_KEY=

# Server-only secrets. Keep these in Supabase/Vercel secret storage, never in browser code.
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
