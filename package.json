{
  "name": "horseshowplatform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:draw": "tsc -p tsconfig.draw-test.json && cp scripts/draw-test-package.json .tmp/draw-tests/package.json && node .tmp/draw-tests/scripts/draw-test-program.js",
    "test:payout": "tsc -p tsconfig.payout-test.json && cp scripts/draw-test-package.json .tmp/payout-tests/package.json && node .tmp/payout-tests/scripts/payout-test-program.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "supabase": "^2.102.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
